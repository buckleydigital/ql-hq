# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only — NEVER expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Agency master keys (stored in Supabase Vault, referenced here for local dev)
# AGENCY_OPEN_AI_API_KEY=sk-...
# AGENCY_TWILIO_ACCOUNT_SID=AC...
# AGENCY_TWILIO_AUTH_TOKEN=...

# Edge-function secrets (add these in Supabase Dashboard → Edge Functions → Secrets)
# Used as a fallback when Vault / api_keys resolution is not configured.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# OPEN_AI_API_KEY=sk-...

# Sign-up activation key — required for new user registration.
# Set this in Supabase Dashboard → Edge Functions → Secrets.
# SIGNUP_ACTIVATION_KEY=your-secret-activation-key-here

# VAPI webhook secret — secures the vapi-webhook endpoint.
# Generate a random string and set it in Supabase Dashboard → Edge Functions → Secrets.
# VAPI will send this as the x-vapi-secret header on every webhook request.
# REQUIRED — the vapi-webhook function will reject all requests if this is not set.
# VAPI_WEBHOOK_SECRET=your-random-webhook-secret-here

# Twilio webhook URL — the exact public URL configured in the Twilio console for
# your inbound SMS webhook (e.g. https://<project>.supabase.co/functions/v1/twilio-inbound-sms).
# REQUIRED — the twilio-inbound-sms function rejects all requests if this is not set.
# TWILIO_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/twilio-inbound-sms

# CORS — set the allowed origin for edge-function responses.
# Defaults to "*" (all origins) when unset, which is required for the public REST API.
# For tighter security, set to your dashboard domain (e.g. https://app.quoteleads.com.au).
# ALLOWED_ORIGIN=*

# Resend sender address — override the default "from" for all outbound emails.
# Useful if your verified Resend domain differs from the default.
# Format: "Display Name <user@yourdomain.com>"
# RESEND_FROM_EMAIL=QuoteLeadsHQ <noreply@quoteleads.com.au>

# Resend API key — REQUIRED for all email sending (password resets, invites,
# AI appointment/quote notifications). Get from https://resend.com/api-keys
# Set in Supabase Dashboard → Edge Functions → Secrets.
# RESEND_API_KEY=re_...

# Site URL — public URL of your dashboard, used in password-reset and invite
# email links. Without this, links redirect to http://localhost:3000 in
# production and the emails will appear to work but the links won't.
# Set in Supabase Dashboard → Edge Functions → Secrets.
# SITE_URL=https://your-domain.com

# Cloudflare Turnstile secret — verifies CAPTCHA tokens for login, signup,
# and password reset. When absent, CAPTCHA verification is bypassed entirely.
# Get from https://dash.cloudflare.com/ → Turnstile → your site → Secret key.
# Set in Supabase Dashboard → Edge Functions → Secrets.
# CF_TURNSTILE_SECRET=0x...
